# ============================================================
#  GlobalChat Connect — Environment Configuration
#  Copy this file to .env and fill in your real credentials
#  NEVER commit .env to version control
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
BASE_URL=https://yourdomain.com

# ── SAFARICOM DARAJA API ─────────────────────────────────────
# Get these from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# Your Till Number (Buy Goods) or Paybill shortcode
MPESA_BUSINESS_SHORTCODE=your_till_or_paybill_number

# Lipa Na M-Pesa Online Passkey (from Daraja portal)
MPESA_PASSKEY=your_lipa_na_mpesa_passkey

# STK Push callback URL — must be HTTPS and publicly reachable
# For local testing use ngrok: https://xxxx.ngrok.io/api/mpesa/callback
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback

# Environment: sandbox | production
MPESA_ENVIRONMENT=sandbox

# Registration fee amount (KES)
MPESA_AMOUNT=100

# ── DATABASE ─────────────────────────────────────────────────
# SQLite (default, no setup needed) — file path relative to backend/
DB_PATH=./db/globalchat.db

# ── SECURITY ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# Admin portal credentials (change immediately in production)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe@2024!

# ── EMAIL (optional — for verification emails) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# ── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
STK_RATE_LIMIT_MAX=5
